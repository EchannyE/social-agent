    {
      "parameters": {
        "promptType": "define",
        "text": "Caption: {{ $json.text }}\nTheme: {{ $json.theme }}\nPlatform: {{ $json.platform }}",
        "messages": {
          "messageValues": [
            {
              "type": "HumanMessagePromptTemplate",
              "message": "=You are an expert AI image prompt engineer. Based on the caption provided, generate ONE high-quality image prompt. Rules: - Maximum 60 words - Photorealistic, professional quality - Include subject, lighting, color palette, composition, mood - No text in the image - Optimized for square format (Instagram/LinkedIn). Return ONLY the prompt. No explanation."
