      "name": "HTTP Request"
    },
    {
      "parameters": {
        "jsCode": "const themeInput = $('Set Theme Input').first().json;\nconst captionChainOutput = $('Chain 1 - Caption + Hashtags').first().json;\nconst imagePromptOutput = $('Chain 2 - Image Prompt Writer').first().json;\nconst incoming = $input.first();\n\nconst rawCaption = captionChainOutput.text || '';\nlet caption = '';\nlet hashtags = '';\n\nconst captionMatch = rawCaption.match(/CAPTION:\\s*([\\s\\S]*?)(?=HASHTAGS:|$)/i);\nconst hashtagMatch = rawCaption.match(/HASHTAGS:\\s*([\\s\\S]*?)$/i);\n\nif (captionMatch) caption = captionMatch[1].trim();\nif (hashtagMatch) hashtags = hashtagMatch[1].trim();\n\nconst fullText = [caption, hashtags].filter(Boolean).join('\\n\\n');\n\nconst binaryKey = incoming.binary ? Object.keys(incoming.binary)[0] : null;\nconst file = binaryKey ? incoming.binary[binaryKey] : null;\nconst mimeType = file?.mimeType || 'image/png';\nconst base64 = file?.data || null;\nconst extension = mimeType.split('/')[1] || 'png';\nconst fileName = file?.fileName || `social-visual.${extension}`;\nconst dataUri = base64 ? `data:${mimeType};base64,${base64}` : null;\n\nreturn [{\n  json: {\n    metadata: {\n      generatedAt: new Date().toISOString(),\n      platform: themeInput.platform,\n      theme: themeInput.theme,\n      tone: themeInput.tone\n    },\n    post: {\n      caption,\n      hashtags,\n      fullText,\n      characterCount: fullText.length\n    },\n    image: {\n      prompt: imagePromptOutput.text || '',\n      mimeType,\n      fileName,\n      dataUri,\n      previewHtml: dataUri ? `<img src=\"${dataUri}\" alt=\"generated image\" style=\"max-width:100%;height:auto;border-radius:12px;\" />` : null\n    },\n    status: {\n      captionGenerated: !!caption,\n      imageGenerated: !!base64,\n      readyToPost: !!(caption && base64)\n    }\n  },\n  binary: incoming.binary\n}];"
      },
      "id": "40214760-75fc-4f89-a126-faa94b20fd01",
